<Window x:Class="WpfDay3Exercise07.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ćwiczenie 7 - MVVM Toolkit ObservableObject" Height="460" Width="720">
    <StackPanel Margin="28">
        <TextBlock Text="MVVM Toolkit: ObservableObject" FontSize="28" FontWeight="Bold" Margin="0,0,0,20" />
        <TextBlock Text="Imię" />
        <TextBox Text="{Binding FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="34" Margin="0,6,0,14" />
        <TextBlock Text="Nazwisko" />
        <TextBox Text="{Binding LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="34" Margin="0,6,0,20" />
        <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="12" Padding="18">
            <TextBlock Text="{Binding FullName}" FontSize="26" FontWeight="Bold" />
        </Border>
    </StackPanel>
</Window>
