<Window x:Class="WpfDay3Exercise04.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ćwiczenie 4 - CommandParameter" Height="500" Width="780">
    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <ListBox Grid.Column="0" ItemsSource="{Binding Runners}" SelectedItem="{Binding SelectedRunner, Mode=TwoWay}" DisplayMemberPath="DisplayName" FontSize="17" Margin="0,0,18,0" />
        <StackPanel Grid.Column="1">
            <TextBlock Text="Zmień status" FontSize="28" FontWeight="Bold" Margin="0,0,0,18" />
            <TextBlock Text="Wybrany:" FontWeight="SemiBold" />
            <TextBlock Text="{Binding SelectedRunner.DisplayName, FallbackValue=brak}" TextWrapping="Wrap" FontSize="18" Margin="0,4,0,20" />
            <Button Content="Status OK" Command="{Binding SetStatusCommand}" CommandParameter="OK" Height="38" Margin="0,0,0,8" />
            <Button Content="Status WARNING" Command="{Binding SetStatusCommand}" CommandParameter="WARNING" Height="38" Margin="0,0,0,8" />
            <Button Content="Status DNF" Command="{Binding SetStatusCommand}" CommandParameter="DNF" Height="38" />
        </StackPanel>
    </Grid>
</Window>
