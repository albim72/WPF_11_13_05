<Window x:Class="WpfDay3Exercise01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ćwiczenie 1 - Struktura MVVM" Height="430" Width="720">
    <Grid Background="#F8FAFC" Margin="24">
        <Border Background="White" CornerRadius="16" BorderBrush="#CBD5E1" BorderThickness="1" Padding="24">
            <StackPanel>
                <TextBlock Text="{Binding ScreenTitle}" FontSize="30" FontWeight="Bold" Margin="0,0,0,18" />
                <TextBlock Text="Zawodnik" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Runner.FullName}" FontSize="24" Foreground="#1D4ED8" Margin="0,4,0,16" />
                <TextBlock Text="Dystans" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Runner.Distance}" FontSize="20" Margin="0,4,0,16" />
                <TextBlock Text="Opis warstw" FontWeight="SemiBold" />
                <TextBlock Text="Model przechowuje dane, View pokazuje XAML, ViewModel przygotowuje dane dla widoku." TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
