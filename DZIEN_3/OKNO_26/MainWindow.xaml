<Window x:Class="WpfDay3Exercise06.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfDay3Exercise06"
        Title="Ćwiczenie 6 - Behavior" Height="440" Width="680">
    <StackPanel Margin="28">
        <TextBlock Text="Behavior: Enter przechodzi dalej" FontSize="28" FontWeight="Bold" Margin="0,0,0,20" />
        <TextBlock Text="Imię" />
        <TextBox local:EnterKeyBehavior.MoveFocusOnEnter="True" Height="34" Margin="0,6,0,14" />
        <TextBlock Text="Nazwisko" />
        <TextBox local:EnterKeyBehavior.MoveFocusOnEnter="True" Height="34" Margin="0,6,0,14" />
        <TextBlock Text="Miasto" />
        <TextBox local:EnterKeyBehavior.MoveFocusOnEnter="True" Height="34" Margin="0,6,0,20" />
        <Button Content="Zapisz" Height="40" Width="140" HorizontalAlignment="Left" />
        <TextBlock Text="Wpisz tekst i naciśnij Enter. Behavior przeniesie fokus bez kodu w oknie." TextWrapping="Wrap" Margin="0,20,0,0" />
    </StackPanel>
</Window>
