<Window x:Class="lista_zawodnikow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lista_zawodnikow"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,24,0">
            <TextBlock Text="Nowy zawodnik" FontSize="26" FontWeight="Bold" Margin="0,0,0,18" />

            <TextBlock Text="Imię" FontWeight="SemiBold" />
            <TextBox x:Name="FirstNameTextBox" Height="34" Margin="0,4,0,12" />

            <TextBlock Text="Nazwisko" FontWeight="SemiBold" />
            <TextBox x:Name="LastNameTextBox" Height="34" Margin="0,4,0,12" />

            <TextBlock Text="Dystans" FontWeight="SemiBold" />
            <ComboBox ItemsSource="{Binding Distances}"
                      SelectedItem="{Binding SelectedDistance, Mode=TwoWay}"
                      Height="36" Margin="0,4,0,20" />

            <Button Content="Dodaj zawodnika" Height="42" Click="AddButton_Click" />

            <TextBlock Text="Po kliknięciu przycisku zawodnik zostanie dodany do listy po prawej stronie."
                       TextWrapping="Wrap" Margin="0,18,0,0" Foreground="#475569" />
        </StackPanel>

        <Border Grid.Column="1" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1"
                CornerRadius="12" Padding="18">
            <StackPanel>
                <TextBlock Text="Lista zawodników" FontSize="26" FontWeight="Bold" Margin="0,0,0,16" />
                <ListBox ItemsSource="{Binding Runners}"
                         DisplayMemberPath="DisplayName"
                         Height="380" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
