<UserControl x:Class="WpfDay2Exercise11.Controls.RunnerCard"
             x:Name="root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="96">
    <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="12" Padding="14" Margin="4">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding RunnerName, ElementName=root}" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="{Binding Distance, ElementName=root}" FontSize="15" Foreground="#475569" Margin="0,4,0,0" />
            </StackPanel>
            <Border Grid.Column="1" Background="#DCFCE7" CornerRadius="10" Padding="12,6" VerticalAlignment="Center">
                <TextBlock Text="{Binding Status, ElementName=root}" FontWeight="Bold" Foreground="#166534" />
            </Border>
        </Grid>
    </Border>
</UserControl>
