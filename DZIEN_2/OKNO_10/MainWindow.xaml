<Window x:Class="NameElement_binding.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NameElement_binding"
        mc:Ignorable="d"
        Title="MainWindow" Height="520" Width="800">
    <StackPanel>
        <TextBlock Text="Podgląd danych zawodnika" FontSize="30" FontWeight="Bold" Margin="0,0,0,22"/>

        <TextBlock Text="Wpisz imię i nazwisko zawodnika:" FontSize="18" FontWeight="Bold" Margin="0,0,0,6"/>
        <TextBox x:Name="RunnerNameTextBox" FontSize="36" Margin="0,6,0,18" ></TextBox>

        <TextBlock Text="Poziom doświadczenia" FontWeight="SemiBold"/>
        <Slider x:Name="ExperienceLevelSlider" Minimum="0" Maximum="10" Value="5" 
                TickFrequency="1" IsSnapToTickEnabled="True" Margin="6,6,6,18"
                TickPlacement="BottomRight" AutoToolTipPlacement="TopLeft" AutoToolTipPrecision="0" Height="40"/>

        <Border Background="Beige" BorderBrush="Aquamarine" BorderThickness="1" CornerRadius="12"
                Padding="18">
            <StackPanel>
                <TextBlock Text="Podgląd danych zawodnika" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                <TextBlock FontSize="20" Text="{Binding Text, ElementName=RunnerNameTextBox, 
                    UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock FontSize="20" Text="{Binding Value, ElementName=ExperienceLevelSlider, StringFormat=Poziom: \{0:0.0\}/10}"/>
            </StackPanel>
        </Border>

    </StackPanel>
</Window>
