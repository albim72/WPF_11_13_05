<Window x:Class="Binding_profil_zawodnika.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Binding_profil_zawodnika"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="Cornsilk" Margin="24">
        <Border Background="White" CornerRadius="16" Padding="24" BorderBrush="Coral" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Profil zawodnika" FontSize="30" FontWeight="Bold" Margin="0 0 0 16"/>
                <TextBlock Text="Imię i Nazwisko" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding FullName}" FontSize="24" Margin="0 4 0 16"/>
                <TextBlock Text="Dystans" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Distance}" FontSize="24" Margin="0 4 0 16"/>
                <TextBlock Text="Miasto" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding City}" FontSize="24" Margin="0 4 0 16"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
