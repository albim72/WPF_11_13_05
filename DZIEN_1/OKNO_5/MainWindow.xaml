<Window x:Class="kontrolki.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:kontrolki"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="800">
    <ScrollViewer>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Rejestracja zawodnika"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="#0F172A"
                       Margin="0,0,0,20"/>
            <StackPanel Grid.Row="1"
                        Margin="0,0,0,14">
                <TextBlock Text="Imię"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="FirstNameTextBox"
                         Height="34"
                         FontSize="15" />
            </StackPanel>
            <StackPanel Grid.Row="2"
            Margin="0,0,0,14">
                <TextBlock Text="Nazwisko"
               FontWeight="SemiBold"
               Margin="0,0,0,4"/>
                <TextBox x:Name="LastNameTextBox"
             Height="34"
             FontSize="15" />
            </StackPanel>
            <StackPanel Grid.Row="3"
            Margin="0,0,0,14">
                <TextBlock Text="Distance"
               FontWeight="SemiBold"
               Margin="0,0,0,4"/>
                <ComboBox x:Name="DistanceComboBox"
                          Height="34"
                          FontSize="15">
                    <ComboBoxItem Content="Trail 33km"/>
                    <ComboBoxItem Content="Ultra 45km"/>
                    <ComboBoxItem Content="Winter 50km"/>
                    <ComboBoxItem Content="Vertical 10km"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Row="4"
            Margin="0,0,0,14">
                <TextBlock Text="Data startu"
               FontWeight="SemiBold"
               Margin="0,0,0,4"/>
               <DatePicker x:Name="StartDatePicker"
                           Height="34"
                           FontSize="15"/>
            </StackPanel>

            <StackPanel Grid.Row="6"
            Margin="0,0,0,14">
                <TextBlock Text="Opcje"
               FontWeight="SemiBold"
               Margin="0,0,0,4"/>
                <CheckBox x:Name="MedicalCheckBox"
                         Content="uczestnik na badania lekarskie"
                         Margin="0,0,0,6"/>
                <CheckBox x:Name="RulesCheckBox"
                        Content="uczestnik akceptuje regulamin" />
            </StackPanel>

            <StackPanel Grid.Row="7"
                        Margin="0,0,0,18">
                <TextBlock Text="Opcje"
                            FontWeight="SemiBold"/>
                <RadioButton x:Name="IndividualRadioButton"
                             Content="start indywidualny"
                             IsChecked="True"
                             Margin="0,0,0,6"/>
                <RadioButton x:Name="TeamRadioButton"
                            Content="start drużynowy"
                            IsChecked="False"
                            Margin="0,0,0,6"/>
            </StackPanel>

            <StackPanel Grid.Row="8"
                        Margin="0,0,0,18">
                <TextBlock Text="Przygotowanie profilu"
                FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <ProgressBar x:Name="ProfileProgressBar"
                             Height="20"
                             FontSize="15"
                             Value="66"/>
                <Button x:Name="SaveButton"
                        Content="Zapisz dane"
                        Height="45"
                        Width="120"
                        FontSize="20"
                        Margin="0,10,0,10"/>
            </StackPanel>


        </Grid>
    </ScrollViewer>
</Window>
