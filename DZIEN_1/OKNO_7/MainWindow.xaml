<Window x:Class="WpfDay1Exercise10.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ćwiczenie 10 - ListBox" Height="460" Width="620">
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Lista zawodników" FontSize="26" FontWeight="Bold" Margin="0,0,0,16" />

        <ListBox x:Name="RunnersListBox" Grid.Row="1" FontSize="17" SelectionChanged="RunnersListBox_SelectionChanged">
            <ListBoxItem Content="101 - Anna Nowak" />
            <ListBoxItem Content="203 - Jan Kowalski" />
            <ListBoxItem Content="307 - Piotr Zieliński" />
        </ListBox>

        <TextBlock x:Name="SelectedRunnerTextBlock" Grid.Row="2" FontSize="18" Margin="0,18,0,0" Text="Wybierz zawodnika z listy." />
    </Grid>
</Window>
