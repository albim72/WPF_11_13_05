<Window x:Class="DockPanel_form.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DockPanel_form"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1D4ED8" Padding="16">
            <TextBlock Text="Formularz Zawodnika" FontSize="24" Foreground="White" FontWeight="Bold"/>
        </Border>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="12">
            <Button Content="Anuluj" Margin="0,0,8,0" Width="100" Height="35"/>
            <Button Content="Zapisz" Width="100" Height="35"/>
        </StackPanel>

        <StackPanel Margin="24" VerticalAlignment="Top">
            <TextBlock Text="Imię:" FontSize="16" Margin="0,4,0,14"/>
            <TextBox Height="30" Margin="0,0,0,12"/>
            <TextBlock Text="Nazwisko:" FontSize="16" Margin="0,4,0,14"/>
            <TextBox Height="30" Margin="0,0,0,12"/>
            <TextBlock Text="Numer Startowy:" FontSize="16" Margin="0,4,0,14"/>
            <TextBox Height="30" Margin="0,0,0,12"/>
        </StackPanel>
    </DockPanel>

</Window>
