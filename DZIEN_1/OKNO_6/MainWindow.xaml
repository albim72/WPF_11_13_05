<Window x:Class="Race_cutoff_judge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Race_cutoff_judge"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="28">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="190"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Race Cutoff Judge" FontSize="30" FontWeight="Bold" Margin="0,0,0,22"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Imię" FontSize="14" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" Name="FirstNameTextBox" Height="20" Margin="0,5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Nazwisko" FontSize="14" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" Name="LastNameTextBox" Height="20" Margin="0,5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Czas na punkcie [min]" FontSize="14" VerticalAlignment="Center"/>
        <TextBox Grid.Row="3" Grid.Column="1" Name="TimeTextBox" Height="20" Margin="0,5"/>

        <Button Grid.Row="4" Grid.Column="1" Content="Oceń zawodnika" Name="JudgeButton" Height="40" Width="180" HorizontalAlignment="Left" Margin="0,14,0,0"></Button>

        <Border Grid.Row="5" Grid.ColumnSpan="2" BorderBrush="Gray" Background="CornflowerBlue" CornerRadius="14" Padding="18" BorderThickness="1" Margin="0,25,0,0">
            <TextBlock Name="ResultTextBlock" Text="Wynik oceny zawodnika pojawi się tutaj...." FontSize="20" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"/>

        </Border>

    </Grid>
</Window>
