<Window x:Class="Race_cutoff_judge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Race_cutoff_judge"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="28">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="190"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Race Cutoff Judge" FontSize="30" FontWeight="Bold" Margin="0,0,0,22"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Imię" FontSize="14" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" Name="FirstNameTextBox" Height="20" Margin="0,5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Nazwisko" FontSize="14" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" Name="LastNameTextBox" Height="20" Margin="0,5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Czas na punkcie [min]" FontSize="14" VerticalAlignment="Center"/>
        <TextBox Grid.Row="3" Grid.Column="1" Name="TimeTextBox" Height="20" Margin="0,5"/>
    </Grid>
</Window>
