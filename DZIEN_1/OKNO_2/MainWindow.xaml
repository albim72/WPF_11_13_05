<Window x:Class="WpfDay1Exercise03.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ćwiczenie 3 - Grid" Height="520" Width="760">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#0F172A" Padding="18">
            <TextBlock Text="Race Control Dashboard" Foreground="White" FontSize="26" FontWeight="Bold" />
        </Border>

        <StackPanel Grid.Row="1" Grid.Column="0" Background="#E2E8F0" Padding="18">
            <Button Content="Zawodnicy" Margin="0,0,0,8" Height="36" />
            <Button Content="Punkty kontrolne" Margin="0,0,0,8" Height="36" />
            <Button Content="Raport" Height="36" />
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="1" Background="#F8FAFC" Padding="24">
            <TextBlock Text="Tutaj pojawi się główna treść aplikacji."
                       FontSize="22" TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#CBD5E1" Padding="10">
            <TextBlock Text="Status: aplikacja gotowa" />
        </Border>
    </Grid>
</Window>
