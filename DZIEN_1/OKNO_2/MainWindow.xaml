<Window x:Class="Grid_cols_rows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Grid_cols_rows"
        mc:Ignorable="d"
        Title="MainWindow" Height="520" Width="760">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Row="0" Grid.ColumnSpan="2" BorderBrush="#1D4ED8" Padding="18">
            <TextBlock Text="Race Control Dashboard" 
                       Foreground="White" 
                       FontSize="26" 
                       FontWeight="Bold"/>
        </Border>
        <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#DBEAFE" Padding="10">
            <TextBlock Text="Dzisiaj monitorujemy punkt kontrolny: Przełęcz Kondracka." 
                       Foreground="#1E3A8A" 
                       FontSize="14"/>
        </Border>
        <StackPanel Grid.Row="2"
                    Grid.Column="0"
                    Background="#E2E8F0">
            <Button Content="Zawodnicy"
                    Margin="0,0,0,8"
                    Height="36"/>
            <Button Content="Punkty Kontrolne"
                    Margin="0,0,0,8"
                    Height="36"/>
            <Button Content="Raaport"
                    Margin="0,0,0,8"
                    Height="36"/>
            <Button Content="Ustawienia" 
                    Height="36"/>
            
        </StackPanel>
        <Grid Grid.Row="2"
              Grid.Column="1"
              Background="#F8FAFC">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="24">
                <TextBlock Text="Tutaj pojawi się główna część aplikacji"
                           FontSize="22"
                           TextWrapping="Wrap"/>
            </Border>
            <Border Grid.Row="1"
                    Background="#E0F2FE"
                    Padding="14"
                    Margin="24">
                <TextBlock Text="Panel szczegółów: brak wybranego zawodnika"
                            FontSize="22"
                            TextWrapping="Wrap"/>
            </Border>

            <Border Grid.Row="3"
                    Grid.ColumnSpan="2"
                    Background="#CBD5E1"
                    Padding="10">
                <TextBlock Text="Status: aplikacja gotowa"/>
            </Border>



        </Grid>
    </Grid>
</Window>
