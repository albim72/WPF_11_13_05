<Window x:Class="Buttons_.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Buttons_"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <ScrollViewer>
        <StackPanel>
            <TextBlock Text="WrapPanel -> kafelki zawodów" FontSize="24" FontWeight="Bold" Margin="0,0,0,12" />
            <WrapPanel Margin="0,0,0,24">
                <Border Width="150" Height="90" Background="#DBEAFE" CornerRadius="12" Margin="6" Padding="10">
                    <TextBlock Text="Ultra 45km" FontSize="17" FontWeight="Bold" />
                </Border>

                <Border Width="150" Height="90" Background="PaleTurquoise" CornerRadius="12" Margin="6" Padding="10">
                    <TextBlock Text="Trail 33km" FontSize="17" FontWeight="Bold" />
                </Border>

                <Border Width="150" Height="90" Background="Gold" CornerRadius="12" Margin="6" Padding="10">
                    <TextBlock Text="Vertical" FontSize="17" FontWeight="Bold" />
                </Border>

                <Border Width="150" Height="90" Background="#33AAF7" CornerRadius="12" Margin="6" Padding="10">
                    <TextBlock Text="Winter 50km" FontSize="17" FontWeight="Bold" />
                </Border>
            </WrapPanel>
            <TextBlock Text="UniformGrid -> równe przyciski" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>
            <UniformGrid Columns="3" Rows="2">
                <Button Content="A" Margin="4" Height="55" />
                <Button Content="B" Margin="4" Height="55" />
                <Button Content="C" Margin="4" Height="55" />
                <Button Content="D" Margin="4" Height="55" />
                <Button Content="E" Margin="4" Height="55" />
                <Button Content="F" Margin="4" Height="55" />
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</Window>
